{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoPaw",
  "version": "0.0.4",
  "identifier": "com.copaw.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "npm --prefix console run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "frontendDist": "../console/dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "CoPaw",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "url": "loading.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright (c) 2024 CoPaw Team",
    "targets": ["dmg", "app"],
    "externalBin": [
      "binaries/copaw-backend"
    ],
    "resources": [
      "loading.html"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "CoPaw - Personal Assistant that runs in your own environment. It talks to you over multiple channels and runs scheduled tasks.",
    "macOS": {
      "entitlements": "entitlements/app.entitlements",
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "shortDescription": "CoPaw Personal Assistant",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
